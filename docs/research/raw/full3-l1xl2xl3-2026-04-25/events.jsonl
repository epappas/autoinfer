{"schema": "v1", "run_id": "29f19904b21c", "event_id": "10f7b00a5a94", "event_n": 57, "ts": 1777136922.8539538, "type": "trial_start", "layer": "l3_kernel", "trial_id": "l3_kernel_w0002", "phase": "warmstart", "config": {"target_op": "rope", "dtype": "float32", "shape_regime": "small", "entry_fn": "rope_optimized_kernel", "source": "import torch\n\ndef rope_optimized_kernel(q, cos, sin):\n    q_reshaped = q.view(*q.shape[:-1], -1, 2)\n    q_even = q_reshaped[..., 0]\n    q_odd = q_reshaped[..., 1]\n    \n    cos_reshaped = cos.view(*cos.shape[:-1], -1, 2)[..., 0]\n    sin_reshaped = sin.view(*sin.shape[:-1], -1, 2)[..., 0]\n    \n    out_even = q_even * cos_reshaped - q_odd * sin_reshaped\n    out_odd = q_even * sin_reshaped + q_odd * cos_reshaped\n    \n    out_reshaped = torch.stack([out_even, out_odd], dim=-1)\n    return out_reshaped.view_as(q)"}}
