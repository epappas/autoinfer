{"schema": "v1", "run_id": "29f19904b21c", "event_id": "fe0f24d1a800", "event_n": 55, "ts": 1777136922.851282, "type": "trial_start", "layer": "l3_kernel", "trial_id": "l3_kernel_w0001", "phase": "warmstart", "config": {"target_op": "silu_mul", "dtype": "float16", "shape_regime": "medium", "entry_fn": "silu_mul_fused_kernel", "source": "import torch\n\ndef silu_mul_fused_kernel(a):\n    x, y = a.chunk(2, dim=-1)\n    sigmoid_x = torch.sigmoid(x)\n    return x * sigmoid_x * y"}}
