{"schema": "v1", "run_id": "29f19904b21c", "event_id": "383d9c01b3f5", "event_n": 53, "ts": 1777136918.7121706, "type": "trial_start", "layer": "l3_kernel", "trial_id": "l3_kernel_w0000", "phase": "warmstart", "config": {"target_op": "rmsnorm", "dtype": "bfloat16", "shape_regime": "large", "entry_fn": "rmsnorm_triton_kernel", "source": "import torch\nimport triton\nimport triton.language as tl\n\n@triton.jit\ndef _rmsnorm_kernel(\n    x_ptr, w_ptr, out_ptr,\n    n_cols, eps,\n    BLOCK_SIZE: tl.constexpr,\n):\n    row_idx = tl.program_id(0)\n    col_offsets = tl.arange(0, BLOCK_SIZE)\n    mask = col_offsets < n_cols\n    \n    x_row_ptr = x_ptr + row_idx * n_cols\n    out_row_ptr = out_ptr + row_idx * n_cols\n    \n    x = tl.load(x_row_ptr + col_offsets, mask=mask, other=0.0).to(tl.float32)\n    w = tl.load(w_ptr + col_offsets, mask=mask, other=0.0).to(tl.float32)\n    \n    x_squared = x * x\n    mean_x_squared = tl.sum(x_squared, axis=0) / n_cols\n    rms = tl.rsqrt(mean_x_squared + eps)\n    \n    out = x * rms * w\n    tl.store(out_row_ptr + col_offsets, out.to(x_ptr.dtype.element_ty), mask=mask)\n\ndef rmsnorm_triton_kernel(x, w, eps):\n    orig_shape = x.shape\n    x_flat = x.view(-1, x.shape[-1])\n    n_rows, n_cols = x_flat.shape\n    \n    out = torch.empty_like(x_flat)\n    \n    BLOCK_SIZE = triton.next_power_of_2(n_cols)\n    grid = (n_rows,)\n    \n    _rmsnorm_kernel[grid](\n        x_flat, w, out,\n        n_cols, eps,\n        BLOCK_SIZE=BLOCK_SIZE,\n    )\n    \n    return out.view(orig_shape)"}}
