{"schema": "v1", "run_id": "6fb695a9b158", "event_id": "f1421f616b36", "event_n": 75, "ts": 1777196526.2033353, "type": "trial_start", "layer": "l3_kernel", "trial_id": "l3_kernel_w0002", "phase": "warmstart", "config": {"target_op": "rope", "dtype": "float32", "shape_regime": "small", "entry_fn": "rope_optimized_kernel", "source": "import torch\n\ndef rope_optimized_kernel(q, cos, sin):\n    # Reshape for vectorized operations\n    q_reshaped = q.view(*q.shape[:-1], -1, 2)\n    cos_reshaped = cos.view(*cos.shape[:-1], -1, 1)\n    sin_reshaped = sin.view(*sin.shape[:-1], -1, 1)\n    \n    # Extract even and odd components\n    q_even = q_reshaped[..., 0]\n    q_odd = q_reshaped[..., 1]\n    \n    # Squeeze the last dimension for broadcasting\n    c = cos_reshaped.squeeze(-1)\n    s = sin_reshaped.squeeze(-1)\n    \n    # Compute rotated components\n    rotated_even = q_even * c - q_odd * s\n    rotated_odd = q_even * s + q_odd * c\n    \n    # Stack and reshape back\n    result = torch.stack([rotated_even, rotated_odd], dim=-1)\n    return result.view_as(q)"}}
