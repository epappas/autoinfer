{"schema": "v1", "run_id": "6dfc163d94f5", "event_id": "63d99b67af54", "event_n": 22, "ts": 1777130106.7557604, "type": "trial_start", "layer": "l3_kernel", "trial_id": "l3_kernel_w0001", "phase": "warmstart", "config": {"target_op": "silu_mul", "dtype": "float16", "shape_regime": "medium", "entry_fn": "silu_mul_kernel", "source": "import torch\nimport triton\nimport triton.language as tl\n\n@triton.jit\ndef silu_mul_triton_kernel(\n    a_ptr, out_ptr,\n    n_elements, n_cols,\n    BLOCK_SIZE: tl.constexpr,\n):\n    pid = tl.program_id(0)\n    block_start = pid * BLOCK_SIZE\n    offsets = block_start + tl.arange(0, BLOCK_SIZE)\n    mask = offsets < n_elements\n    \n    # Load input\n    a_vals = tl.load(a_ptr + offsets, mask=mask, other=0.0)\n    \n    # Split into x and y (first half and second half of last dimension)\n    half_cols = n_cols // 2\n    col_idx = offsets % n_cols\n    \n    # Determine if we're in first or second half\n    is_first_half = col_idx < half_cols\n    \n    # Get corresponding x and y values\n    x_offset = offsets - tl.where(is_first_half, 0, half_cols)\n    y_offset = offsets + tl.where(is_first_half, half_cols, -half_cols)\n    \n    x_vals = tl.where(is_first_half, a_vals, tl.load(a_ptr + x_offset, mask=mask, other=0.0))\n    y_vals = tl.where(is_first_half, tl.load(a_ptr + y_offset, mask=mask, other=0.0), a_vals)\n    \n    # Compute SiLU(x) * y, but only store for first half positions\n    silu_x = x_vals / (1.0 + tl.exp(-x_vals))\n    result = silu_x * y_vals\n    \n    # Only store results for the output positions (first half size)\n    out_mask = mask & is_first_half\n    out_offsets = offsets - tl.where(is_first_half, 0, half_cols)\n    tl.store(out_ptr + out_offsets, result, mask=out_mask)\n\ndef silu_mul_kernel(a):\n    try:\n        *batch_dims, n_cols = a.shape\n        n_elements = a.numel()\n        out_cols = n_cols // 2\n        out_shape = (*batch_dims, out_cols)\n        out = torch.empty(out_shape, dtype=a.dtype, device=a.device)\n        \n        BLOCK_SIZE = 1024\n        grid = (triton.cdiv(n_elements, BLOCK_SIZE),)\n        \n        silu_mul_triton_kernel[grid](\n            a, out,\n            n_elements, n_cols,\n            BLOCK_SIZE=BLOCK_SIZE,\n        )\n        return out\n    except:\n        # Fallback to reference implementation\n        x, y = a.chunk(2, dim=-1)\n        return torch.nn.functional.silu(x) * y"}}
