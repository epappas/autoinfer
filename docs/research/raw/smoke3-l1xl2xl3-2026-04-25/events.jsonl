{"schema": "v1", "run_id": "6dfc163d94f5", "event_id": "280617f3a95b", "event_n": 24, "ts": 1777130107.150081, "type": "trial_start", "layer": "l3_kernel", "trial_id": "l3_kernel_w0002", "phase": "warmstart", "config": {"target_op": "rope", "dtype": "float32", "shape_regime": "small", "entry_fn": "rope_kernel", "source": "import torch\n\ndef rope_kernel(q, cos, sin):\n    # Optimized version using torch operations with better memory access patterns\n    q_reshaped = q.view(*q.shape[:-1], q.shape[-1] // 2, 2)\n    q_even = q_reshaped[..., 0]\n    q_odd = q_reshaped[..., 1]\n    \n    # Ensure cos and sin have the right shape\n    cos_reshaped = cos[..., 0::2] if cos.shape[-1] == q.shape[-1] else cos\n    sin_reshaped = sin[..., 0::2] if sin.shape[-1] == q.shape[-1] else sin\n    \n    # Compute rotated values\n    rotated_even = q_even * cos_reshaped - q_odd * sin_reshaped\n    rotated_odd = q_even * sin_reshaped + q_odd * cos_reshaped\n    \n    # Stack and reshape back\n    rotated = torch.stack([rotated_even, rotated_odd], dim=-1)\n    return rotated.view_as(q)"}}
